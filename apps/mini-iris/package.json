{
  "name": "mini-iris",
  "version": "1.0.32",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.interceptor.config.ts && node build-zip.cjs",
    "clean": "rm -rf dist builds",
    "check": "npm run lint && npm run typecheck && npm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@iris/core": "*",
    "maplibre-gl": "^5.24.0",
    "preact": "^10.29.1",
    "rbush": "^4.0.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.7.0",
    "@types/rbush": "^4.0.0",
    "archiver": "^8.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.2"
  }
}
