{
  "manifest_version": 3,
  "name": "Mini IRIS",
  "version": "1.0.1",
  "description": "Compact IRIS map experience with an alternate UI and interaction model",
  "host_permissions": [
    "https://intel.ingress.com/*",
    "https://*.basemaps.cartocdn.com/*",
    "https://*.tile.openstreetmap.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://intel.ingress.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://intel.ingress.com/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "mini-iris@iris.debug",
      "strict_min_version": "109.0"
    }
  }
}
