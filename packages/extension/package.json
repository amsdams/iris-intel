{
  "name": "@iris/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build --mode chrome",
    "build:chrome": "vite build --mode chrome",
    "build:firefox": "vite build --mode firefox",
    "build:all": "npm run build:chrome && npm run build:firefox",
    "clean": "rm -rf dist dist-firefox",
    "check": "npm run lint && npm run typecheck && npm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@iris/core": "*",
    "preact": "^10.19.0",
    "zustand": "^4.0.0",
    "maplibre-gl": "^4.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.7.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-web-extension": "^4.1.0"
  }
}
