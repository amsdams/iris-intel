{
  "name": "@iris/extension",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build --mode chrome",
    "build:chrome": "vite build --mode chrome",
    "build:firefox": "vite build --mode firefox",
    "build:all": "npm run build:chrome && npm run build:firefox",
    "package": "npm run build:all && node build-package.cjs",
    "package:chrome": "npm run build:chrome && node build-package.cjs chrome",
    "package:firefox": "npm run build:firefox && node build-package.cjs firefox",
    "clean": "rm -rf dist dist-firefox builds",
    "check": "npm run lint && npm run typecheck && npm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@iris/core": "*",
    "maplibre-gl": "^5.24.0",
    "preact": "^10.29.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.7.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vite-plugin-web-extension": "^4.5.1"
  }
}
