{
  "manifest_version": 3,
  "name": "Map Interaction POC (Vite/TS)",
  "version": "1.0.0",
  "description": "POC to test layered map interactions in Firefox Mobile extensions",
  "host_permissions": [
    "https://www.google.com/*",
    "https://*.basemaps.cartocdn.com/*",
    "https://*.tile.openstreetmap.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "poc-map-interaction-v2@iris.debug",
      "strict_min_version": "109.0"
    }
  }
}
