{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "paths": {
      "@iris/core": ["./packages/core/src"],
      "@iris/plugin-sdk": ["./packages/plugin-sdk/src"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "poc-map-interaction/src/**/*.ts",
    "poc-map-interaction/src/**/*.tsx",
    "vitest.setup.ts"
  ],
  "exclude": ["node_modules"]
}
