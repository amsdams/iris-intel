{
  "name": "iris-monorepo",
  "private": true,
  "version": "0.1.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:iris",
    "dev:iris": "npm run dev -w packages/extension",
    "dev:mini-iris": "npm run dev -w apps/mini-iris",
    "build": "npm run build:all",
    "build:core": "npm run build -w packages/core",
    "build:iris": "npm run build -w packages/extension",
    "build:iris:chrome": "npm run build:chrome -w packages/extension",
    "build:iris:firefox": "npm run build:firefox -w packages/extension",
    "build:mini-iris": "npm run build -w apps/mini-iris",
    "build:all": "npm run build -ws --if-present",
    "clean": "npm run clean:all",
    "clean:core": "npm run clean -w packages/core",
    "clean:iris": "npm run clean -w packages/extension",
    "clean:mini-iris": "npm run clean -w apps/mini-iris",
    "clean:all": "npm run clean -ws --if-present",
    "check": "npm run check:all",
    "check:core": "npm run check -w packages/core",
    "check:iris": "npm run check -w packages/extension",
    "check:mini-iris": "npm run check -w apps/mini-iris",
    "check:all": "npm run check -ws --if-present",
    "test": "npm run test:all",
    "test:core": "npm run test -w packages/core",
    "test:iris": "npm run test -w packages/extension",
    "test:mini-iris": "npm run test -w apps/mini-iris",
    "test:all": "npm run test -ws --if-present",
    "test:core:store-bounds": "vitest run packages/core/src/store.bounds.test.ts",
    "typecheck": "npm run typecheck:all",
    "typecheck:core": "npm run typecheck -w packages/core",
    "typecheck:iris": "npm run typecheck -w packages/extension",
    "typecheck:mini-iris": "npm run typecheck -w apps/mini-iris",
    "typecheck:all": "npm run typecheck -ws --if-present",
    "lint": "npm run lint:all && npm run lint:css",
    "lint:core": "npm run lint -w packages/core",
    "lint:iris": "npm run lint -w packages/extension",
    "lint:mini-iris": "npm run lint -w apps/mini-iris",
    "lint:all": "npm run lint -ws --if-present",
    "version:bump": "bash ./scripts/release-version.sh",
    "release:iris:chrome": "npm run package:chrome -w packages/extension",
    "release:iris:firefox": "npm run package:firefox -w packages/extension",
    "release:iris": "npm run package -w packages/extension",
    "lint:fix": "npm run lint:fix:all && npm run lint:css:fix",
    "lint:fix:core": "npm run lint:fix -w packages/core",
    "lint:fix:iris": "npm run lint:fix -w packages/extension",
    "lint:fix:mini-iris": "npm run lint:fix -w apps/mini-iris",
    "lint:fix:all": "npm run lint:fix -ws --if-present",
    "lint:css": "stylelint '**/*.css'",
    "lint:css:fix": "stylelint '**/*.css' --fix",
    "serve": "npx qrcode-terminal http://$(ipconfig getifaddr en0):8080 && npx http-server -p 8080"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.4.2",
    "vite-plugin-web-extension": "^4.5.1",
    "vitest": "^4.1.6"
  }
}
